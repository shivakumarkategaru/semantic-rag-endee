# ─── Endee Configuration ──────────────────────────────────────────────
ENDEE_HOST=http://localhost:8080
ENDEE_AUTH_TOKEN=              # Leave empty for no-auth dev mode
ENDEE_INDEX_NAME=rag_knowledge_base

# ─── Embedding Model ──────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2   # or sentence-transformers/all-mpnet-base-v2

# ─── Generator (optional LLM) ─────────────────────────────────────────
USE_LLM=false                       # Set to "true" to enable LLM answer synthesis
GENERATOR_MODEL=distilgpt2          # or "facebook/opt-125m", "gpt2"

# ─── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
